rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /apps {
    	allow read: if true;
      allow write: if false;
    }
    match /exam_logos {
    	allow read, write: if request.auth != null;
    }
    match /sales_outlets {
    	allow read, write: if request.auth != null;
    }
  }
}
